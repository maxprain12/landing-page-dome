---
import ManyMascot from "./ManyMascot.astro";

// v2.3.5 — order matches the strength narrative: agent → index → studio →
// agents+canvas → editor → providers → feeders → integrations.
const features = [
  {
    k: "01",
    t: "Many — Dome-native agent",
    p: "A reasoning agent on the @dome/agent-core harness: persistent JSONL sessions, context budget with live token estimates, multimodal attachments, web search, MCP tools, and human-in-the-loop resume. LangGraph is gone — this is Dome's own runtime.",
  },
  {
    k: "02",
    t: "Configurable semantic index",
    p: "LangChain embeddings (OpenAI, Google Gemini, Ollama) in LanceDB, with hybrid search (vectors + FTS + graph) and PDF/image text via your cloud LLM (vision). Switch the embedding model in Settings; Dome reindexes for you.",
  },
  {
    k: "03",
    t: "Studio · Learn with FSRS",
    p: "Generate mindmaps, quizzes, study guides, FAQs, and timelines from your sources. Flashcards now use FSRS (ts-fsrs) with backfill from legacy SM-2 decks, 3D flip study UI, and interval previews on the action buttons.",
  },
  {
    k: "04",
    t: "Agents, Canvas, Teams, Workflows",
    p: "Custom agents with their own instructions, MCP servers, and JSONL sessions. Agent Canvas (D3 + SVG) for visual flows, agent teams in shared chat, and a DAG workflow executor with per-node retry and text-only propagation.",
  },
  {
    k: "05",
    t: "Notion-style editor + viewers",
    p: "Tiptap with slash commands, tables, columns, toggles, callouts. PDF viewer (highlight, underline, comment), PowerPoint viewer (no LibreOffice), and academic library citations (APA, MLA, Chicago, Harvard, Vancouver, IEEE).",
  },
  {
    k: "06",
    t: "Your AI provider",
    p: "OpenAI, Anthropic, Google, Ollama, OpenRouter, DeepSeek, Moonshot, Qwen, GitHub Copilot, MiniMax. Provider-specific tool normalization, multimodal support, and a unified model catalog discoverable from the chat composer.",
  },
  {
    k: "07",
    t: "Feeders — data pipelines",
    p: "Scheduled sandbox scripts (Python, Node, Bash, curl) that feed persisted artifacts with external JSON (Redfish, APIs, custom). Encrypted secrets vault (safeStorage), HITL approval modal, run history, and agent tools (feeder_*).",
  },
  {
    k: "08",
    t: "Marketplace + skills from GitHub",
    p: "Install community agents, plugins, workflows, and skills. Paste a GitHub URL in Settings → Skills → Install from GitHub to add a skill with one click; the marketplace can browse multi-skill repos for you.",
  },
] as const;

const ink = "var(--color-text)";
const rule = "var(--color-border)";
const sage = "var(--color-accent-light)";
const rust = "var(--color-rust)";

function glyphHtml(i: number): string {
  if (i === 0) {
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 42 C12 22 22 12 35 12 C48 12 58 22 58 42 L58 48 L12 48 Z" fill="none" stroke="${ink}" stroke-width="1.8"/>
      <circle cx="28" cy="32" r="2.5" fill="${ink}"/><circle cx="42" cy="32" r="2.5" fill="${ink}"/>
      <path d="M27 42 Q35 46 43 42" fill="none" stroke="${ink}" stroke-width="1.5"/>
    </svg>`;
  }
  if (i === 1) {
    const lines = [0, 1, 2, 3]
      .map(
        (y) => `<line x1="8" x2="62" y1="${12 + y * 9}" y2="${12 + y * 9}" stroke="${ink}" stroke-width="1"/>`,
      )
      .join("");
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      ${lines}
      <rect x="26" y="16" width="18" height="24" fill="none" stroke="${rust}" stroke-width="2"/>
      <text x="35" y="33" font-family="Instrument Serif,serif" font-size="12" text-anchor="middle" font-style="italic" fill="${rust}">+FTS</text>
    </svg>`;
  }
  if (i === 2) {
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="10" width="18" height="14" fill="${sage}" stroke="${ink}"/>
      <rect x="28" y="18" width="18" height="14" fill="none" stroke="${ink}"/>
      <rect x="50" y="28" width="14" height="14" fill="${rust}" stroke="${ink}"/>
      <text x="15" y="22" font-family="Instrument Serif,serif" font-size="10" text-anchor="middle" fill="${ink}">map</text>
      <text x="37" y="30" font-family="Instrument Serif,serif" font-size="10" text-anchor="middle" fill="${ink}">quiz</text>
      <text x="57" y="40" font-family="Instrument Serif,serif" font-size="10" text-anchor="middle" fill="#fff">deck</text>
    </svg>`;
  }
  if (i === 3) {
    const pos = [
      [10, 14],
      [35, 8],
      [58, 14],
      [22, 40],
      [48, 40],
    ];
    const rects = pos
      .map(
        ([x, y], j) =>
          `<rect x="${x - 6}" y="${y - 4}" width="12" height="8" fill="${j === 1 ? sage : "none"}" stroke="${ink}"/>`,
      )
      .join("");
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      ${rects}
      <g stroke="${ink}" stroke-width="1" fill="none">
        <line x1="16" y1="14" x2="29" y2="8"/><line x1="41" y1="8" x2="52" y2="14"/>
        <line x1="16" y1="14" x2="22" y2="36"/><line x1="52" y1="14" x2="48" y2="36"/>
        <line x1="22" y1="40" x2="48" y2="40"/>
      </g>
    </svg>`;
  }
  if (i === 4) {
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="6" width="58" height="42" fill="#fff" stroke="${ink}"/>
      <text x="12" y="20" font-family="Instrument Serif,serif" font-size="11" fill="${ink}">Chapter 04</text>
      <line x1="12" y1="26" x2="58" y2="26" stroke="${rule}"/><line x1="12" y1="32" x2="50" y2="32" stroke="${rule}"/>
      <line x1="12" y1="38" x2="44" y2="38" stroke="${rule}"/>
      <rect x="12" y="41" width="16" height="4" fill="${sage}"/>
    </svg>`;
  }
  if (i === 5) {
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      ${["GPT", "CLA", "GEM", "OLL", "OPR"]
      .map(
        (m, j) => `<g>
        <rect x="${4 + j * 13}" y="14" width="11" height="26" fill="${j === 3 ? sage : "none"}" stroke="${ink}"/>
        <text x="${9.5 + j * 13}" y="50" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="6" fill="${ink}" letter-spacing="0.5">${m}</text>
      </g>`,
      )
      .join("")}
    </svg>`;
  }
  if (i === 6) {
    // Feeders pipeline: script → secrets → approval → artifact
    return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="20" width="14" height="14" fill="none" stroke="${ink}"/>
      <text x="9" y="30" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="6" fill="${ink}">{}</text>
      <line x1="16" y1="27" x2="22" y2="27" stroke="${ink}" stroke-width="1" stroke-dasharray="2 2"/>
      <rect x="22" y="20" width="14" height="14" fill="${sage}" stroke="${ink}"/>
      <text x="29" y="30" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="6" fill="${ink}">k</text>
      <line x1="36" y1="27" x2="42" y2="27" stroke="${ink}" stroke-width="1" stroke-dasharray="2 2"/>
      <rect x="42" y="20" width="14" height="14" fill="none" stroke="${rust}" stroke-width="1.4"/>
      <text x="49" y="30" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="6" fill="${rust}">HITL</text>
      <line x1="56" y1="27" x2="62" y2="27" stroke="${ink}" stroke-width="1" stroke-dasharray="2 2"/>
      <rect x="62" y="22" width="6" height="10" fill="${ink}"/>
    </svg>`;
  }
  // i === 7 — Marketplace: 3 stacked "install" cards
  return `<svg class="gli" width="70" height="54" viewBox="0 0 70 54" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <rect x="6" y="14" width="44" height="10" fill="none" stroke="${ink}"/>
    <circle cx="11" cy="19" r="2" fill="${sage}"/>
    <line x1="16" y1="19" x2="36" y2="19" stroke="${ink}" stroke-width="0.7"/>
    <rect x="6" y="26" width="44" height="10" fill="${sage}" stroke="${ink}"/>
    <circle cx="11" cy="31" r="2" fill="${ink}"/>
    <line x1="16" y1="31" x2="36" y2="31" stroke="${ink}" stroke-width="0.7"/>
    <text x="46" y="34" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="6" fill="${ink}">+</text>
    <rect x="6" y="38" width="44" height="10" fill="none" stroke="${ink}"/>
    <circle cx="11" cy="43" r="2" fill="${rust}"/>
    <line x1="16" y1="43" x2="36" y2="43" stroke="${ink}" stroke-width="0.7"/>
  </svg>`;
}
---

<section class="fe" id="features" aria-labelledby="fe-h2">
  <div class="fe-in">
    <div class="fe-head">
      <div>
        <p class="fe-ey">— What's inside · v2.3.5</p>
        <h2 id="fe-h2" class="fe-h2">Eight things Dome does well, in one quiet workspace.</h2>
      </div>
      <div class="fe-mascot" aria-hidden="true">
        <ManyMascot variant="think" size={72} />
      </div>
    </div>

    <div class="fe-grid" role="list">
      {features.map((f, i) => (
        <article
          class:list={["fe-card", { "is-first": i === 0 }]}
          data-i={i}
          role="listitem"
        >
          <p class="fe-fig">FIG. {f.k}</p>
          <h3 class="fe-t">{f.t}</h3>
          <p class="fe-p">{f.p}</p>
          <div class="fe-glyph" set:html={glyphHtml(i)} />
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .fe {
    background: var(--color-paper-deep);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 5.5rem 0;
  }

  .fe-in {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .fe-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .fe-ey {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 0.6rem;
  }

  .fe-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.1vw, 2.3rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    font-weight: 400;
    margin: 0;
    max-width: 32rem;
  }

  .fe-mascot {
    flex-shrink: 0;
  }

  .fe-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .fe-card {
    padding: 1.6rem 1.5rem 1.4rem;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    min-height: 16.5rem;
  }

  .fe-card:nth-child(4n) {
    border-right: none;
  }

  /* Last row: drop the bottom border on the last 4 cards */
  .fe-card:nth-child(n + 5) {
    border-bottom: none;
  }

  .fe-card.is-first {
    background: var(--color-accent-light);
  }

  .fe-fig {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--color-ink-3);
    margin: 0 0 0.2rem;
  }

  .fe-card.is-first .fe-fig {
    color: var(--color-sage-dark);
  }

  .fe-t {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1.3vw, 1.3rem);
    line-height: 1.08;
    font-weight: 400;
    color: var(--color-text);
    margin: 0.4rem 0;
    letter-spacing: -0.02em;
  }

  .fe-p {
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 0.4rem;
  }

  :global(.fe-glyph .gli) {
    display: block;
    margin-top: 0.9rem;
  }

  @media (max-width: 1180px) {
    .fe-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .fe-card:nth-child(2n) {
      border-right: none;
    }
    .fe-card:nth-child(n + 7) {
      border-bottom: none;
    }
    .fe-card.is-first {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 960px) {
    .fe-grid {
      grid-template-columns: 1fr;
    }

    .fe-card {
      border-right: none;
    }

    .fe-card:nth-child(n) {
      border-bottom: 1px solid var(--color-border);
    }

    .fe-card:last-child {
      border-bottom: none;
    }
  }
</style>
