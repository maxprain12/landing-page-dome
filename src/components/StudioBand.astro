---
const items = [
  { t: "Mindmap", g: 0 },
  { t: "Quiz", g: 1 },
  { t: "Timeline", g: 2 },
  { t: "Flashcards · FSRS", g: 3 },
  { t: "Study guide", g: 4 },
  { t: "FAQ", g: 5 },
];
---

<section class="sb" id="studio" aria-labelledby="sb-heading">
  <div class="sb-inner">
    <div class="sb-head">
      <div>
        <p class="sb-label">— Studio</p>
        <h2 id="sb-heading" class="sb-h2">
          Mindmaps, quizzes, flashcards, guides, FAQs, and timelines — every output cited, every card graded by FSRS.
        </h2>
      </div>

      {/* Interactive mockup of <FlashPlayerSession /> with a real 3D flip. */}
      <figure class="sb-flash" data-flash aria-label="Flashcard study mockup with FSRS interval buttons">
        <div class="sb-flash-card" data-flash-card>
          <div class="sb-flash-front">
            <p class="sb-flash-ey">Front · Card 7 of 24 · due now</p>
            <p class="sb-flash-q">What is FSRS?</p>
            <p class="sb-flash-hint">Free Spaced Repetition Scheduler — open algorithm, no vendor lock-in. Click to reveal.</p>
          </div>
          <div class="sb-flash-back">
            <p class="sb-flash-ey">Back · click to flip back</p>
            <p class="sb-flash-a">
              FSRS (ts-fsrs in Dome) replaces legacy SM-2. Cards are scheduled per-card based on
              your rating history. Dome backfills your existing decks on first launch.
            </p>
          </div>
        </div>
        <div class="sb-flash-actions">
          <button type="button" class="sb-flash-btn">Again<span>1m</span></button>
          <button type="button" class="sb-flash-btn">Hard<span>6m</span></button>
          <button type="button" class="sb-flash-btn sb-flash-btn-ok">Good<span>3d</span></button>
          <button type="button" class="sb-flash-btn">Easy<span>12d</span></button>
        </div>
        <figcaption>
          <code>FlashPlayerSession</code> · 3D flip · FSRS interval previews. Click the card to flip.
        </figcaption>
      </figure>
    </div>

    <div class="sb-grid" role="list">
      {items.map((item) => (
        <div class="sb-cell" role="listitem">
          <h3 class="sb-t">{item.t}</h3>
          <div class="sb-glyph" aria-hidden="true">
            {item.g === 0 && (
              <svg width="60" height="40" viewBox="0 0 60 40">
                {[
                  [15, 12],
                  [30, 6],
                  [45, 12],
                  [22, 30],
                  [38, 30],
                ].map(([x, y], j) => <circle cx={x} cy={y} r="3" fill="var(--color-accent-light)" />)}
                <g stroke="var(--color-paper-light)" stroke-width="1" fill="none" opacity="0.7">
                  <line x1="15" y1="12" x2="30" y2="6" />
                  <line x1="30" y1="6" x2="45" y2="12" />
                  <line x1="15" y1="12" x2="22" y2="30" />
                  <line x1="45" y1="12" x2="38" y2="30" />
                  <line x1="22" y1="30" x2="38" y2="30" />
                </g>
              </svg>
            )}
            {item.g === 1 && <span class="sb-q">?</span>}
            {item.g === 2 && (
              <svg width="90" height="24" viewBox="0 0 90 24">
                <line x1="0" y1="12" x2="90" y2="12" stroke="var(--color-paper-light)" stroke-width="1" />
                {[12, 36, 60, 84].map((x) => (
                  <circle cx={x} cy="12" r="3" fill="var(--color-accent-light)" />
                ))}
              </svg>
            )}
            {item.g === 3 && (
              <svg width="56" height="40" viewBox="0 0 56 40">
                <rect
                  x="4"
                  y="6"
                  width="34"
                  height="24"
                  fill="none"
                  stroke="var(--color-paper-light)"
                  stroke-width="1"
                  transform="rotate(-5 21 18)"
                />
                <rect x="14" y="8" width="34" height="24" fill="var(--color-accent-light)" stroke="var(--color-paper-light)" stroke-width="1" />
              </svg>
            )}
            {item.g === 4 && (
              <svg width="60" height="40" viewBox="0 0 60 40">
                {[0, 1, 2, 3].map((j) => (
                  <g>
                    <circle cx="4" cy={6 + j * 10} r="2" fill="var(--color-accent-light)" />
                    <line
                      x1="10"
                      y1={6 + j * 10}
                      x2={[50, 40, 48, 32][j] ?? 32}
                      y2={6 + j * 10}
                      stroke="var(--color-paper-light)"
                      stroke-width="1"
                    />
                  </g>
                ))}
              </svg>
            )}
            {item.g === 5 && <span class="sb-faq">FAQ</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Interactive flashcard flip on click. CSS handles the 3D rotation; the
  // script just toggles the [data-flipped] attribute.
  document.querySelectorAll<HTMLElement>("[data-flash]").forEach((root) => {
    const card = root.querySelector<HTMLElement>("[data-flash-card]");
    if (!card) return;
    card.addEventListener("click", () => {
      card.toggleAttribute("data-flipped");
    });
    card.style.cursor = "pointer";
  });
</script>

<style>
  .sb {
    background: var(--color-sage-dark);
    color: var(--color-paper-light);
    padding: 96px 48px;
  }

  .sb-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .sb-head {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 48px;
  }

  .sb-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.7;
    margin: 0 0 10px;
  }

  .sb-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.1rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
    font-weight: 400;
    max-width: 640px;
  }

  /* --- FlashPlayerSession mockup (interactive 3D flip) --- */
  .sb-flash {
    margin: 0;
    padding: 18px 18px 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    perspective: 1200px;
  }
  .sb-flash-card {
    position: relative;
    min-height: 168px;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0.0, 0.2, 1);
  }
  .sb-flash-card[data-flipped] { transform: rotateY(180deg); }
  .sb-flash-front,
  .sb-flash-back {
    position: absolute; inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-paper-light);
    color: var(--color-text);
    border-radius: 6px;
    padding: 14px 16px;
    box-sizing: border-box;
  }
  .sb-flash-front { transform: rotateY(0deg); }
  .sb-flash-back  { transform: rotateY(180deg); }
  .sb-flash-ey {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 8px;
  }
  .sb-flash-q {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.1;
    margin: 0 0 6px;
  }
  .sb-flash-hint {
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .sb-flash-a {
    font-size: 12px;
    line-height: 1.45;
    color: var(--color-text);
    margin: 0;
  }
  .sb-flash-actions {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    margin-top: 12px;
  }
  .sb-flash-btn {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-paper-light);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 4px;
    padding: 6px 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: center;
    line-height: 1.1;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .sb-flash-btn:hover { background: rgba(255, 255, 255, 0.16); transform: translateY(-1px); }
  .sb-flash-btn span { opacity: 0.7; font-size: 9px; }
  .sb-flash-btn-ok { background: var(--color-accent-light); color: var(--color-sage-dark); border-color: var(--color-accent-light); }
  .sb-flash-btn-ok:hover { background: var(--color-accent-light); }
  .sb-flash figcaption {
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    opacity: 0.6;
  }
  .sb-flash code {
    background: rgba(255, 255, 255, 0.08);
    padding: 1px 5px;
    border-radius: 3px;
  }

  /* --- Studio grid (cells) --- */
  .sb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .sb-cell {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 28px 24px;
    min-height: 132px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .sb-cell:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  .sb-t {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    margin: 0;
    line-height: 1.1;
  }

  .sb-glyph { flex-shrink: 0; }

  .sb-q {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-style: italic;
    color: var(--color-accent-light);
    line-height: 1;
  }

  .sb-faq {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-style: italic;
    color: var(--color-accent-light);
  }

  @media (max-width: 960px) {
    .sb-head {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .sb {
      padding: 72px 20px;
    }
    .sb-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
