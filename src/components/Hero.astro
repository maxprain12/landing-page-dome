---
import ManyMascot from "./ManyMascot.astro";

const releases = "https://github.com/maxprain12/dome/releases";
const github = "https://github.com/maxprain12/dome";
---

<section class="ha" aria-labelledby="ha-h1">
  <div class="ha-spark ha-sp1" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 20 20"
      ><path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
        fill="var(--color-accent)"></path></svg>
  </div>
  <div class="ha-spark ha-sp2" aria-hidden="true">
    <svg width="14" height="14" viewBox="0 0 20 20"
      ><path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
        fill="var(--color-rust)"></path></svg>
  </div>
  <div class="ha-spark ha-sp3" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 20 20"
      ><path
        d="M10 0 L11.5 8.5 L20 10 L11.5 11.5 L10 20 L8.5 11.5 L0 10 L8.5 8.5 Z"
        fill="var(--color-accent)"></path></svg>
  </div>

  <div class="ha-grid">
    <div class="ha-left">
      <p class="ha-eyebrow">— Open source · Electron · LangGraph · Many AI</p>
      <h1 id="ha-h1" class="ha-h1">
        Your knowledge,<br />
        <span class="ha-h1b">
          under one dome.
          <svg class="ha-under" viewBox="0 0 400 20" aria-hidden="true" preserveAspectRatio="none">
            <path
              d="M4 14 Q 80 4, 160 10 T 396 8"
              fill="none"
              stroke="var(--color-accent-light)"
              stroke-width="5"
              stroke-linecap="round"
            />
          </svg>
        </span>
      </h1>
      <p class="ha-sub">
        Intelligent desktop app for knowledge management and academic research. Organize
        notes, PDFs, videos, and URLs in projects — then let AI index, search, and
        synthesize your library, with Many (LangGraph) at your side.
      </p>
      <div class="ha-cta-row">
        <a class="ha-btn-pill" href={releases} target="_blank" rel="noopener">
          <svg width="14" height="16" viewBox="0 0 14 16" fill="currentColor" aria-hidden="true"
            ><path
              d="M10.3 8.5c0-1.8 1.5-2.7 1.6-2.7-.9-1.3-2.2-1.5-2.7-1.5-1.2-.1-2.2.7-2.8.7-.6 0-1.5-.7-2.4-.6C2.7 4.4 1.6 5.1 1 6.2c-1.3 2.2-.3 5.5.9 7.3.6.9 1.3 1.9 2.3 1.8.9 0 1.3-.6 2.4-.6s1.4.6 2.4.6c1 0 1.6-.9 2.2-1.8.7-1 1-2 1-2.1 0 0-1.9-.7-1.9-2.9zM8.5 3c.5-.6.9-1.5.7-2.4-.8 0-1.7.5-2.3 1.1-.5.5-.9 1.4-.7 2.3.9.1 1.8-.5 2.3-1z"
            ></path></svg>
          Download for Mac
        </a>
        <div class="ha-sec">
          <div>Windows · Linux</div>
          <div class="ha-tiny">Open source. Local or cloud — your choice.</div>
        </div>
      </div>
      <div class="ha-gh">
        <a class="ha-gh-link" href={github} target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path></svg>
          <span><strong>2.4k</strong> ★ on GitHub</span>
        </a>
        <span class="ha-dot" aria-hidden="true">·</span>
        <span>Built by <a class="ha-tw" href="https://github.com/maxprain12" target="_blank" rel="noopener"
          ><strong>@maxprain12</strong></a
        ></span>
      </div>
    </div>

    <div class="ha-scene" aria-hidden="true">
      <div class="book book-a">METHOD</div>
      <div class="book book-b">NOTES</div>
      <div class="book book-c">ARCHIVE</div>

      <div class="ha-paper">
        <p class="ha-paper-ey">Paper · 2024</p>
        <p class="ha-paper-title">On the emergence of habits in long research projects.</p>
        {[
          95, 78, 92, 60, 85, 40,
        ].map((w) => <div class="ha-line" style={`width: ${w}%;`} />)}
        <div class="ha-badge">✦ Indexed</div>
      </div>

      <div class="ha-postit">ask Many to summarise <u>ch. 4</u> by friday</div>

      <div class="ha-many">
        <ManyMascot variant="glasses" size={200} class="ha-many-img" />
        <p class="ha-manysay">← hi, I&apos;m Many</p>
      </div>
    </div>
  </div>
</section>

<style>
  .ha {
    max-width: 1240px;
    margin: 0 auto;
    padding: 20px 48px 64px;
    position: relative;
    overflow-x: clip;
  }

  .ha-spark {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .ha-sp1 {
    top: 12px;
    left: 12%;
  }

  .ha-sp2 {
    top: 48px;
    right: 22%;
  }

  .ha-sp3 {
    top: 220px;
    left: 5%;
  }

  @media (max-width: 900px) {
    .ha-spark {
      display: none;
    }
  }

  .ha-grid {
    position: relative;
    z-index: 1;
    /* Columna derecha nunca < 360px: evita que la "paper" y los lomos se pisen */
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(360px, 440px);
    gap: 2rem 2.5rem;
    align-items: start;
  }

  .ha-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 1.1rem;
  }

  .ha-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.2vw, 4.1rem);
    line-height: 0.94;
    letter-spacing: -0.06em;
    font-weight: 400;
    margin: 0 0 1.25rem;
    text-wrap: balance;
  }

  .ha-h1b {
    font-style: italic;
    color: var(--color-sage-dark);
    position: relative;
    display: inline-block;
  }

  .ha-under {
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 14px;
  }

  .ha-sub {
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 35rem;
    margin: 0 0 1.6rem;
  }

  .ha-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .ha-btn-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    padding: 0.9rem 1.45rem;
    font-size: 0.95rem;
    font-weight: 500;
    border: none;
    border-radius: 999px;
    text-decoration: none;
    font-family: var(--font-sans);
  }

  .ha-btn-pill:hover {
    opacity: 0.9;
  }

  .ha-sec {
    font-size: 0.8rem;
    color: var(--color-ink-3);
  }

  .ha-tiny {
    font-size: 0.68rem;
    margin-top: 0.2rem;
  }

  .ha-gh {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.2rem;
    font-size: 0.8rem;
    color: var(--color-ink-3);
  }

  .ha-gh a {
    color: inherit;
  }

  .ha-gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }

  .ha-gh-link:hover,
  .ha-tw:hover {
    color: var(--color-text);
  }

  .ha-gh strong,
  .ha-tw strong {
    color: var(--color-text);
  }

  .ha-dot {
    opacity: 0.6;
  }

  .ha-left {
    min-width: 0;
  }

  .ha-scene {
    position: relative;
    width: 100%;
    min-height: 28rem;
    /* altura fija mínima evita colapsos raros al medir; contenido con coordenadas relativas al box */
  }

  .book {
    position: absolute;
    z-index: 1;
    width: 2.4rem;
    height: 8.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: clamp(0.6rem, 1.4vw, 0.9rem);
    padding: 0.5rem 0;
    color: var(--color-surface);
    border-radius: 2px 2px 4px 4px;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
    writing-mode: vertical-rl;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .book-a {
    top: 4%;
    right: 20%;
    background: var(--color-accent);
    transform: rotate(-3deg);
  }

  .book-b {
    top: 6%;
    right: 6%;
    background: var(--color-rust);
    transform: rotate(4deg);
  }

  .book-c {
    top: 8%;
    right: 35%;
    background: var(--color-text);
    transform: rotate(-8deg);
  }

  .ha-paper {
    position: absolute;
    z-index: 2;
    top: 32%;
    right: 0;
    left: 0;
    width: 92%;
    max-width: 15.5rem;
    min-width: 12rem;
    margin-left: auto;
    box-sizing: border-box;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    box-shadow: 0 10px 28px rgba(48, 38, 20, 0.12);
    transform: rotate(-2deg);
  }

  .ha-paper-ey {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0;
  }

  .ha-paper-title {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.1vw, 1.1rem);
    line-height: 1.2;
    margin: 0.4rem 0 0.6rem;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .ha-line {
    height: 2px;
    border-radius: 1px;
    background: var(--color-border);
    margin-top: 0.3rem;
  }

  .ha-badge {
    position: absolute;
    top: -5px;
    right: 10px;
    background: var(--color-accent-light);
    color: var(--color-sage-dark);
    padding: 2px 8px;
    font-size: 9px;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    border-radius: 2px;
  }

  .ha-postit {
    position: absolute;
    z-index: 2;
    top: 60%;
    right: 2%;
    max-width: 8.2rem;
    padding: 0.5rem 0.6rem;
    background: #f7d76b;
    font-family: var(--font-hand);
    font-size: clamp(0.85rem, 1.1vw, 1.05rem);
    line-height: 1.15;
    color: var(--color-text);
    transform: rotate(6deg);
    box-shadow: 0 4px 12px rgba(48, 38, 20, 0.14);
  }

  .ha-many {
    position: absolute;
    z-index: 3;
    bottom: 0;
    left: 0;
  }

  .ha-many :global(.many-wrap img) {
    width: 12.5rem;
    max-width: 100%;
    height: auto;
  }

  .ha-manysay {
    font-family: var(--font-hand);
    font-size: clamp(0.85rem, 1vw, 1.05rem);
    color: var(--color-text-secondary);
    margin: 0.15rem 0 0 0.5rem;
    transform: rotate(-3deg);
    white-space: normal;
    max-width: 12rem;
  }

  @media (max-width: 1024px) {
    .ha {
      padding: 0.5rem 20px 2rem;
    }

    .ha-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .ha-scene {
      min-height: 22rem;
      max-width: 26rem;
      margin: 0 auto;
    }
  }

  @media (max-width: 520px) {
    .book {
      display: none;
    }

    .ha-postit {
      right: 4%;
      top: 52%;
    }

    .ha-paper {
      top: 28%;
    }
  }
</style>
