---
import Screen from "./Screen.astro";
import ManyMascot from "./ManyMascot.astro";
---

<section class="mm" id="meet-many" aria-labelledby="mm-heading">
  <div class="mm-grid">
    <div>
      <p class="mm-eyebrow">— Many AI assistant</p>
      <h2 id="mm-heading" class="mm-h2">
        LangGraph-powered chat: web search, your resources, memory, and MCP tools.
      </h2>
      <p class="mm-body">
        Many sits on top of a semantic index (Nomic embeddings in SQLite) with hybrid
        search (vectors, full-text, graph). Use OpenAI, Anthropic, Google, or Ollama — run
        local or in the cloud. Ask in plain language; Many cites where it can.
      </p>
      <div class="mm-quote">
        <ManyMascot variant="think" size={80} />
        <p class="mm-quote-txt">&quot;Your library is indexed. What should we find first?&quot;</p>
      </div>
    </div>
    <div>
      <Screen
        src="/assets/screen-many.png"
        title="Dome · Many"
        caption="Many in your workspace"
      />
    </div>
  </div>
</section>

<style>
  .mm {
    max-width: 1240px;
    margin: 0 auto;
    padding: 5.5rem 48px 5rem;
    background: var(--color-surface);
  }

  .mm-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }

  .mm-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 16px;
  }

  .mm-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.2vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 20px;
    font-weight: 400;
  }

  .mm-body {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0;
  }

  .mm-quote {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .mm-quote-txt {
    font-family: var(--font-hand);
    font-size: 24px;
    color: var(--color-ink-3);
    max-width: 260px;
    line-height: 1.2;
    margin: 0;
  }

  @media (max-width: 900px) {
    .mm {
      padding: 64px 20px;
    }

    .mm-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
