---
import MockHome from "./MockHome.astro";
---

<section class="ps" id="product" aria-label="Product screenshot">
  <div class="ps-inner">
    <div class="ps-sticker">v2.3.5 · The Dome workspace</div>
    <MockHome />
  </div>
</section>

<style>
  .ps {
    background: var(--color-bg);
    padding: 80px 48px 100px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .ps-inner {
    max-width: 1240px;
    margin: 0 auto;
    position: relative;
  }

  .ps-sticker {
    position: absolute;
    top: -18px;
    left: 0;
    z-index: 3;
    transform: rotate(-6deg);
    background: var(--color-rust);
    color: var(--color-surface);
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    box-shadow: 0 4px 14px rgba(138, 62, 26, 0.28);
  }

  @media (max-width: 700px) {
    .ps {
      padding: 64px 20px 72px;
    }
  }
</style>
