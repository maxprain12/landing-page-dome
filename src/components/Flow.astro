---
const flow = [
  {
    n: "01",
    t: "Add your sources",
    p: "Notes, PDFs, videos, and URLs in projects. Google Drive, Calendar, WhatsApp, web — connect what you use.",
  },
  {
    n: "02",
    t: "Index & search",
    p: "Nomic embeddings and hybrid search in SQLite keep your library queryable in the background.",
  },
  { n: "03", t: "Talk to Many", p: "Web search, resources, memory, and MCP — ask, cite, and iterate." },
  { n: "04", t: "Studio & agents", p: "Mindmaps, flashcards, timelines; your agents, Canvas, and marketplace extensions." },
];

const bg = [
  "var(--color-accent-light)",
  "var(--color-rust)",
  "var(--color-text)",
  "var(--color-accent)",
];
const fg = [
  "var(--color-text)",
  "var(--color-surface)",
  "var(--color-surface)",
  "var(--color-surface)",
];
---

<section class="fo" id="flow" aria-labelledby="fo-h2">
  <div class="fo-in">
    <div class="fo-head">
      <p class="fo-ey">— The flow</p>
      <h2 id="fo-h2" class="fo-h2">From a pile of PDFs to a mind of your own.</h2>
    </div>
    <div class="fo-row" role="list">
      <svg class="fo-dash" viewBox="0 0 1000 8" preserveAspectRatio="none" aria-hidden="true">
        <line
          x1="0"
          y1="4"
          x2="1000"
          y2="4"
          stroke="var(--color-border)"
          stroke-width="2"
          stroke-dasharray="4 6"
        />
      </svg>
      {flow.map((step, i) => (
        <div class="fo-step" role="listitem" style={`--b:${bg[i]};--f:${fg[i]}`}>
          <div class="fo-n">{step.n}</div>
          <h3 class="fo-t">{step.t}</h3>
          <p class="fo-p">{step.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .fo {
    max-width: 1240px;
    margin: 0 auto;
    padding: 5rem 48px 5.2rem;
    background: var(--color-surface);
  }

  .fo-in {
    position: relative;
  }

  .fo-head {
    text-align: center;
    margin-bottom: 2.2rem;
  }

  .fo-ey {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 0.4rem;
  }

  .fo-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.1vw, 2.3rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
    font-weight: 400;
    margin: 0 auto;
    max-width: 32rem;
  }

  .fo-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem 1.2rem;
    position: relative;
    padding-top: 0.2rem;
  }

  .fo-dash {
    position: absolute;
    top: 1.1rem;
    left: 3.2rem;
    right: 3.2rem;
    width: calc(100% - 6.4rem);
    height: 8px;
    z-index: 0;
  }

  .fo-step {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .fo-n {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    background: var(--b);
    color: var(--f);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    margin: 0 auto;
    border: 2px solid var(--color-surface);
    box-shadow: 0 3px 10px rgba(48, 38, 20, 0.1);
  }

  .fo-t {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    line-height: 1.1;
    margin: 0.9rem 0 0.35rem;
  }

  .fo-p {
    font-size: 0.84rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 900px) {
    .fo {
      padding: 3.5rem 20px 3.5rem;
    }

    .fo-dash {
      display: none;
    }

    .fo-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .fo-row {
      grid-template-columns: 1fr;
    }
  }
</style>
