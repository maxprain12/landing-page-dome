---
// "Provider constellation" — a calm, paper-style strip showing the 10 AI
// providers wired in v2.3.5. Each tile renders the actual SVG logo
// shipped in maxprain12/dome at public/brandlogo/*.svg (copied into
// landing-page-dome/public/brandlogo on PR).

const providers = [
  { src: "/brandlogo/openai.svg",       label: "OpenAI",          featured: true  },
  { src: "/brandlogo/anthropic.svg",    label: "Anthropic"                      },
  { src: "/brandlogo/googlegemini.svg", label: "Google Gemini"                  },
  { src: "/brandlogo/ollama.svg",       label: "Ollama (local)",   featured: true },
  { src: "/brandlogo/openrouter.svg",   label: "OpenRouter",       featured: true },
  { src: "/brandlogo/deepseek.svg",     label: "DeepSeek"                        },
  { src: "/brandlogo/moonshot.svg",     label: "Moonshot"                        },
  { src: "/brandlogo/qwen.svg",         label: "Qwen"                            },
  { src: "/brandlogo/github.svg",       label: "GitHub Copilot"                  },
  { src: "/brandlogo/minimax.svg",     label: "MiniMax"                        },
];
---

<section class="pr" id="providers" aria-labelledby="pr-h2">
  <div class="pr-inner">
    <div class="pr-head">
      <p class="pr-ey">— Your AI provider</p>
      <h2 id="pr-h2" class="pr-h2">Ten providers. One model catalog. Your call, every chat.</h2>
      <p class="pr-sub">
        Switch models in the chat composer, in Settings, or from an agent's config.
        Configurable embeddings, web search, and tool normalization are wired per-provider.
        Run everything local with Ollama, or mix cloud and local in the same session.
      </p>
    </div>

    <ul class="pr-grid" role="list">
      {providers.map((p) => (
        <li
          class:list={["pr-tile", { "is-featured": p.featured }]}
          role="listitem"
          aria-label={p.label}
        >
          <span class="pr-mono" aria-hidden="true">
            <img src={p.src} alt="" loading="lazy" decoding="async" />
          </span>
          <span class="pr-name">{p.label}</span>
          {p.featured && <span class="pr-pick" aria-hidden="true">popular</span>}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .pr {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 80px 48px;
  }

  .pr-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .pr-head {
    max-width: 720px;
    margin-bottom: 36px;
  }

  .pr-ey {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 10px;
  }

  .pr-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 14px;
    font-weight: 400;
  }

  .pr-sub {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .pr-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .pr-tile {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    cursor: default;
  }
  .pr-tile:hover {
    background: var(--color-accent-light);
    transform: translateY(-1px);
    z-index: 2;
    box-shadow: 0 6px 18px rgba(48, 38, 20, 0.12);
  }
  .pr-tile:hover .pr-mono {
    border-color: var(--color-sage-dark);
  }

  .pr-tile:nth-child(5n) { border-right: none; }
  .pr-tile:nth-child(n + 6) { border-bottom: none; }

  .pr-mono {
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    flex-shrink: 0;
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  /* All provider SVGs use currentColor or solid fills; we force them to
     24×24 so they sit nicely inside the 36×36 frame regardless of source
     viewBox. */
  .pr-mono img {
    width: 24px;
    height: 24px;
    display: block;
    object-fit: contain;
  }

  .pr-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .pr-pick {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-rust);
    background: var(--color-bg);
    border: 1px solid var(--color-rust);
    border-radius: 2px;
    padding: 1px 4px;
    line-height: 1.1;
  }

  @media (max-width: 1100px) {
    .pr-grid { grid-template-columns: repeat(3, 1fr); }
    .pr-tile:nth-child(5n) { border-right: 1px solid var(--color-border); }
    .pr-tile:nth-child(3n) { border-right: none; }
    .pr-tile:nth-child(n + 6) { border-bottom: 1px solid var(--color-border); }
    .pr-tile:nth-child(n + 8) { border-bottom: none; }
  }

  @media (max-width: 700px) {
    .pr { padding: 64px 20px; }
    .pr-grid { grid-template-columns: repeat(2, 1fr); }
    .pr-tile { border-right: 1px solid var(--color-border) !important; border-bottom: 1px solid var(--color-border) !important; }
    .pr-tile:nth-child(2n) { border-right: none !important; }
    .pr-tile:nth-last-child(-n+2) { border-bottom: none !important; }
  }
</style>
