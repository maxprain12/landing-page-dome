---
// "Provider constellation" — a calm, paper-style strip showing the 10 AI
// providers wired in v2.3.5. Each tile is a tiny SVG monogram + label so the
// row stays crisp on retina and is keyboard/screen-reader friendly.

const providers = [
  { key: "openai",     label: "OpenAI",          g: 0 },
  { key: "anthropic",  label: "Anthropic",       g: 1 },
  { key: "google",     label: "Google Gemini",   g: 2 },
  { key: "ollama",     label: "Ollama (local)",  g: 3 },
  { key: "openrouter", label: "OpenRouter",      g: 4 },
  { key: "deepseek",   label: "DeepSeek",        g: 5 },
  { key: "moonshot",   label: "Moonshot",        g: 6 },
  { key: "qwen",       label: "Qwen",            g: 7 },
  { key: "copilot",    label: "GitHub Copilot",  g: 8 },
  { key: "minimax",    label: "MiniMax",         g: 9 },
];
---

<section class="pr" id="providers" aria-labelledby="pr-h2">
  <div class="pr-inner">
    <div class="pr-head">
      <p class="pr-ey">— Your AI provider</p>
      <h2 id="pr-h2" class="pr-h2">Ten providers. One model catalog. Your call, every chat.</h2>
      <p class="pr-sub">
        Switch models in the chat composer, in Settings, or from an agent's config.
        Configurable embeddings, web search, and tool normalization are wired per-provider.
        Run everything local with Ollama, or mix cloud and local in the same session.
      </p>
    </div>

    <ul class="pr-grid" role="list">
      {providers.map((p) => (
        <li class="pr-tile" role="listitem" aria-label={p.label}>
          <span class="pr-mono" aria-hidden="true">
            {p.g === 0 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 10 L12 22 M16 10 L16 22 M20 10 L20 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {p.g === 1 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M6 22 Q16 4, 26 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M11 18 H21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            )}
            {p.g === 2 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M16 4 L20 13 L29 14.5 L22.5 21 L24 30 L16 25.5 L8 30 L9.5 21 L3 14.5 L12 13 Z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
              </svg>
            )}
            {p.g === 3 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <rect x="5" y="5" width="22" height="22" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="16" cy="16" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="16" cy="9" r="1.5" fill="currentColor"/>
              </svg>
            )}
            {p.g === 4 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M5 22 Q5 6, 16 6 Q27 6, 27 22 Q27 18, 22 18 L10 18 Q5 18, 5 22 Z" fill="none" stroke="currentColor" stroke-width="1.4"/>
              </svg>
            )}
            {p.g === 5 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M8 8 L24 24 M24 8 L8 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="16" cy="16" r="9" fill="none" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            )}
            {p.g === 6 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M4 24 Q4 12, 16 12 Q28 12, 28 24" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="16" cy="12" r="3" fill="currentColor"/>
              </svg>
            )}
            {p.g === 7 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M6 16 Q16 4, 26 16 Q16 28, 6 16 Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <path d="M16 10 V22 M10 16 H22" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            )}
            {p.g === 8 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <path d="M16 4 L28 22 H4 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                <circle cx="16" cy="18" r="3" fill="currentColor"/>
              </svg>
            )}
            {p.g === 9 && (
              <svg width="32" height="32" viewBox="0 0 32 32">
                <circle cx="16" cy="16" r="11" fill="none" stroke="currentColor" stroke-width="1.4"/>
                <path d="M8 16 Q12 10, 16 16 T24 16" fill="none" stroke="currentColor" stroke-width="1.4"/>
                <path d="M8 16 Q12 22, 16 16 T24 16" fill="none" stroke="currentColor" stroke-width="1.4" opacity="0.5"/>
              </svg>
            )}
          </span>
          <span class="pr-name">{p.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .pr {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 80px 48px;
  }

  .pr-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .pr-head {
    max-width: 720px;
    margin-bottom: 36px;
  }

  .pr-ey {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin: 0 0 10px;
  }

  .pr-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 14px;
    font-weight: 400;
  }

  .pr-sub {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .pr-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .pr-tile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    transition: background 0.18s ease;
  }
  .pr-tile:hover { background: var(--color-accent-light); }

  .pr-tile:nth-child(5n) { border-right: none; }
  .pr-tile:nth-child(n + 6) { border-bottom: none; }

  .pr-mono {
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-sage-dark);
    flex-shrink: 0;
  }

  .pr-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  @media (max-width: 1100px) {
    .pr-grid { grid-template-columns: repeat(3, 1fr); }
    .pr-tile:nth-child(5n) { border-right: 1px solid var(--color-border); }
    .pr-tile:nth-child(3n) { border-right: none; }
    .pr-tile:nth-child(n + 6) { border-bottom: 1px solid var(--color-border); }
    .pr-tile:nth-child(n + 8) { border-bottom: none; }
  }

  @media (max-width: 700px) {
    .pr { padding: 64px 20px; }
    .pr-grid { grid-template-columns: repeat(2, 1fr); }
    .pr-tile { border-right: 1px solid var(--color-border) !important; border-bottom: 1px solid var(--color-border) !important; }
    .pr-tile:nth-child(2n) { border-right: none !important; }
    .pr-tile:nth-last-child(-n+2) { border-bottom: none !important; }
  }
</style>
