# Configuración específica para Coolify

# Variables de entorno necesarias para el despliegue
NODE_ENV=production
NPM_CONFIG_PRODUCTION=false
HOST=0.0.0.0
PORT=3000

# Comandos de construcción (el arranque lo define el Dockerfile: nginx en puerto 80)
BUILD_CMD=npm run build
# No uses START_CMD tipo SPA: el sitio es estático multipágina (/privacy/, /terms/).
